# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_DB_URL=
# LLM
OLLAMA_BASE_URL=
OLLAMA_MODEL=
GROQ_API_KEY=your_groq_api_key_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# Monitoring
PROMETHEUS_ENABLED=true

# App
APP_ENV=development
LOG_LEVEL=DEBUG
UPLOAD_DIR=./uploads

# Mailtrap (Evidence Coordinator)
MAILTRAP_API_KEY=
MAILTRAP_SENDER_EMAIL=
MAILTRAP_SENDER_NAME=

# Credit Rating API
CREDIT_API_MODE=mock
OPENCORPORATES_API_KEY=

# JWT Auth
JWT_SECRET=

# Phase 3 Workflow
AUTO_SIMULATE_APPROVALS=false
MAX_WORKFLOW_RETRIES=2

# Rate Limiting & Timeouts (Groq free tier = 30 RPM)
LLM_REQUESTS_PER_MINUTE=25
AGENT_TIMEOUT_SECONDS=120
